# ============================================================
# Appointment Booking Telegram Bot - Environment Variables
# Copy this file to .env and fill in real values before running.
# ============================================================
# بوت حجز المواعيد لتليجرام - متغيرات البيئة
# انسخ هذا الملف إلى .env واملأ القيم الحقيقية قبل التشغيل.
# ============================================================

# Telegram Bot API token from @BotFather
# رمز واجهة برمجة التطبيقات (API Token) للبوت من @BotFather
BOT_TOKEN=123456789:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghi

# Comma-separated list of Telegram user IDs with admin privileges.
# Get your ID from @userinfobot or similar bots.
# قائمة بمعرفات مستخدمي تليجرام (User IDs) الذين يمتلكون صلاحيات المشرف، مفصولة بفواصل.
# يمكنك الحصول على معرفك من بوت @userinfobot أو بوتات مشابهة.
ADMIN_IDS=12345678,87654321

# SQLite database path (relative to project root).
# Uses data/appointments.db by default.
# مسار قاعدة بيانات SQLite (نسبة إلى المجلد الرئيسي للمشروع).
# يستخدم data/appointments.db بشكل افتراضي.
DATABASE_PATH=data/appointments.db

# Default appointment slot duration in minutes.
# المدة الافتراضية لكل خانة موعد بالدقائق.
SLOT_DURATION_MINUTES=30

# Timezone for schedule generation. SQLite stores naive datetimes in this zone.
# النطاق الزمني المستخدم لإنشاء الجداول. تخزن SQLite التواريخ والأوقات المجردة بناءً على هذا النطاق.
TIMEZONE=UTC

# Business working hours (24-hour format). Can be overridden in schedule_service.py.
# ساعات العمل الرسمية (بتنسيق 24 ساعة). يمكن تعديلها أو تجاوزها داخل ملف schedule_service.py.
WORKING_HOURS_START=09:00
WORKING_HOURS_END=18:00

# Working days as a comma-separated list. 0=Monday, 6=Sunday.
# أيام العمل الرسمية كقائمة مفصولة بفواصل. 0 تعني الإثنين، 6 تعني الأحد.
WORKING_DAYS=0,1,2,3,4

# Default bot language (en, ar, etc.). Used for messages.py fallback.
# اللغة الافتراضية للبوت (en للإنجليزي، ar للعربي، إلخ). تستخدم كخيار احتياطي في ملف messages.py.
DEFAULT_LANGUAGE=en

# Logging level: DEBUG, INFO, WARNING, ERROR
# مستوى تسجيل الأحداث والأخطاء (Logging): DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Allowed range for the number of individuals per booking (inclusive).
# Used by the booking flow to validate the text-based count input.
# النطاق المسموح به لعدد الأفراد في الحجز الواحد (شامل الأرقام المذكورة).
# يستخدم في تدفق الحجز للتحقق من صحة الرقم الذي يدخله المستخدم نصياً.
MIN_BOOKING_INDIVIDUALS=1
MAX_BOOKING_INDIVIDUALS=10

# Retention windows (in days) for automated background cleanup.
# Admin/general archive purges appointments older than ADMIN_RETENTION_DAYS.
# User "My Bookings" history hides appointments older than USER_RETENTION_DAYS,
# and the daily job hard-deletes records past the maximum (USER_RETENTION_DAYS).
# فترات الاحتفاظ بالبيانات (بالأيام) لعملية التنظيف التلقائي في الخلفية.
# أرشيف المشرف العام يقوم بتطهير وحذف المواعيد التي مر عليها أكثر من ADMIN_RETENTION_DAYS.
# سجل "مواعيدي" الخاص بالمستخدم يخفي المواعيد التي مر عليها أكثر من USER_RETENTION_DAYS،
# وتقوم المهمة اليومية بحذف السجلات نهائياً عند تجاوز الحد الأقصى وهو (USER_RETENTION_DAYS).
ADMIN_RETENTION_DAYS=7
USER_RETENTION_DAYS=14